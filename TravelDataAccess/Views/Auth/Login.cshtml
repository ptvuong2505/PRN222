@model TravelDataAccess.Dtos.LoginDto;
@{
    Layout = "_layout";
}

<div>
    <form class="container" asp-action="Login" method="post">
        <div class="mb-3">
            <label asp-for="@Model.Code" class="form-label">Code</label>
            <input type="text" class="form-control" asp-for="@Model.Code">
        </div>
        <div class="mb-3">
            <label asp-for="@Model.Password" class="form-label">Password</label>
            <input type="password" class="form-control" asp-for="@Model.Password">
        </div>
        <button type="submit" class="btn btn-primary">Submit</button>
    </form>
</div>

